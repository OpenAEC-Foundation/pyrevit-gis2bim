<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - Locatie Instellen"
    Width="480"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">
    
    <Window.Resources>
        <!-- Kleuren -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>
    
    <DockPanel LastChildFill="True">
        
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock 
                Text="GIS2BIM - Locatie Instellen" 
                FontSize="18" 
                FontWeight="SemiBold" 
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock 
                x:Name="txt_subtitle"
                Text="PDOK Locatieserver → RD coördinaten" 
                FontSize="12" 
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>
        
        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>
        
        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" 
                BorderBrush="{StaticResource MediumGrayBrush}" 
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren" 
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="Locatie Instellen" 
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                
                <!-- Huidige locatie info -->
                <Border x:Name="pnl_current" 
                        Background="{StaticResource LightGrayBrush}" 
                        Padding="12" 
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="HUIDIGE SURVEY POINT" 
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="RD X:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_current_x" Grid.Row="0" Grid.Column="1" Text="-" 
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="RD Y:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_current_y" Grid.Row="1" Grid.Column="1" Text="-" 
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Invoermethode -->
                <TextBlock Text="INVOERMETHODE" 
                           FontSize="11" FontWeight="SemiBold" 
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,12"/>
                
                <StackPanel Margin="0,0,0,16">
                    <RadioButton x:Name="rb_revit" 
                                 GroupName="method"
                                 Margin="0,0,0,8"
                                 FontSize="13">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Gebruik Revit Site Location" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="txt_revit_location" Text="" 
                                       Foreground="{StaticResource TealBrush}" 
                                       FontWeight="SemiBold" Margin="8,0,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rb_address" 
                                 Content="Adres (plaats + straat + huisnummer)" 
                                 GroupName="method"
                                 IsChecked="True"
                                 Margin="0,0,0,8"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                    <RadioButton x:Name="rb_postcode" 
                                 Content="Postcode + huisnummer" 
                                 GroupName="method"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                
                <!-- Adres invoer -->
                <Border x:Name="pnl_address" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ADRESGEGEVENS" 
                                   FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Plaats -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Plaats" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="txt_city" Grid.Row="1" Grid.Column="0"
                                     Text="" Padding="8,6" FontSize="13"/>
                            
                            <!-- Huisnummer (adres) -->
                            <TextBlock Grid.Row="0" Grid.Column="2" 
                                       Text="Huisnummer" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="txt_number_addr" Grid.Row="1" Grid.Column="2"
                                     Text="" Padding="8,6" FontSize="13"/>
                            
                            <!-- Straat -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="Straat" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="txt_street" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                     Text="" Padding="8,6" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Postcode invoer -->
                <Border x:Name="pnl_postcode" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="POSTCODE" 
                                   FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Postcode (bijv. 3012AA)" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="txt_postcode" Grid.Row="1" Grid.Column="0"
                                     Text="" Padding="8,6" FontSize="13"/>
                            
                            <TextBlock Grid.Row="0" Grid.Column="2" 
                                       Text="Huisnummer" FontSize="11" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="txt_number_post" Grid.Row="1" Grid.Column="2"
                                     Text="" Padding="8,6" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Resultaat -->
                <Border x:Name="pnl_result" 
                        Background="{StaticResource LightGrayBrush}" 
                        Padding="12" 
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEVONDEN LOCATIE" 
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="txt_result_address" Text="-" 
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="RD X:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_result_x" Grid.Row="0" Grid.Column="1" Text="-" 
                                       Foreground="{StaticResource TealBrush}" FontWeight="Bold"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="RD Y:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,4"/>
                            <TextBlock x:Name="txt_result_y" Grid.Row="0" Grid.Column="3" Text="-" 
                                       Foreground="{StaticResource TealBrush}" FontWeight="Bold"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Provincie:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_result_prov" Grid.Row="1" Grid.Column="1" Text="-" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Windgebied:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,4"/>
                            <TextBlock x:Name="txt_result_wind" Grid.Row="1" Grid.Column="3" Text="-" 
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="WGS84:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_result_wgs" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" 
                                       Text="-" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Status/Error -->
                <TextBlock x:Name="txt_status" 
                           Text="" 
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>
                
            </StackPanel>
        </ScrollViewer>
        
    </DockPanel>
</Window>
