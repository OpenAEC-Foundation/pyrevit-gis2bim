<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - AHN Laden"
    Width="520"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <!-- Kleuren -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="GIS2BIM - AHN Laden"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="Actueel Hoogtebestand Nederland"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="AHN Laden"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PROJECTLOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een projectlocatie in via de Locatie tool"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Zoekgebied -->
                <TextBlock Text="ZOEKGEBIED"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Grootte:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_bbox_size" Width="140" Padding="8,6">
                        <ComboBoxItem Content="50 x 50 m" Tag="50"/>
                        <ComboBoxItem Content="100 x 100 m" Tag="100" IsSelected="True"/>
                        <ComboBoxItem Content="200 x 200 m" Tag="200"/>
                        <ComboBoxItem Content="500 x 500 m" Tag="500"/>
                    </ComboBox>
                </StackPanel>

                <!-- Instellingen -->
                <TextBlock Text="INSTELLINGEN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Data type -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Data type:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="rdo_dtm"
                                     Content="DTM (maaiveld)"
                                     GroupName="coverage"
                                     IsChecked="True"
                                     Margin="0,0,20,0"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rdo_dsm"
                                     Content="DSM (oppervlakte)"
                                     GroupName="coverage"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Methode -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Methode:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="rdo_wcs"
                                     Content="WCS (GeoTIFF, langzaam)"
                                     GroupName="method"
                                     Margin="0,0,20,0"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rdo_laz"
                                     Content="LAZ (Puntenwolk, snel)"
                                     GroupName="method"
                                     IsChecked="True"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Resolutie -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Resolutie:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_resolution" Grid.Row="4" Grid.Column="1"
                              Width="200" HorizontalAlignment="Left" Padding="8,6">
                        <ComboBoxItem Content="0.5 m (fijn - native)" Tag="0.5" IsSelected="True"/>
                        <ComboBoxItem Content="1.0 m (normaal)" Tag="1.0"/>
                        <ComboBoxItem Content="2.0 m (grof)" Tag="2.0"/>
                    </ComboBox>

                    <!-- Keep every Nth (thinning) -->
                    <TextBlock x:Name="lbl_keep_nth" Grid.Row="6" Grid.Column="0"
                               Text="Elke Nde punt:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <StackPanel x:Name="pnl_keep_nth" Grid.Row="6" Grid.Column="1"
                                Orientation="Horizontal">
                        <TextBox x:Name="txt_keep_nth"
                                 Width="60" Padding="8,6"
                                 Text=""
                                 ToolTip="Leeg = alle punten behouden"/>
                        <TextBlock Text="(leeg = alle punten)"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Textuur -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Textuur:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_texture" Grid.Row="8" Grid.Column="1"
                              Width="200" HorizontalAlignment="Left" Padding="8,6">
                        <ComboBoxItem Content="Geen" Tag="geen"/>
                        <ComboBoxItem Content="Luchtfoto" Tag="luchtfoto" IsSelected="True"/>
                    </ComboBox>
                </Grid>

                <!-- LAStools status (alleen zichtbaar bij LAZ methode) -->
                <Border x:Name="pnl_lastools"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="LASTOOLS"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource YellowBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="txt_lastools"
                                   Text="Controleren..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Punten schatting -->
                <Border x:Name="pnl_estimate"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <TextBlock x:Name="txt_estimate"
                               Text="Geschat: ~40.000 punten"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met laden..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
