<DockPanel
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Background="{DynamicResource VioletBrush}">
        <TextBlock Text="Sheet Parameters Updater"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="White"
                   Margin="20,16,20,4"/>
        <TextBlock Text="Bulk update sheet en titleblock parameters"
                   FontSize="12" FontWeight="Medium"
                   Foreground="{DynamicResource TealBrush}"
                   Margin="20,0,20,16"/>
    </StackPanel>

    <!-- Accent Line -->
    <Rectangle DockPanel.Dock="Top" Height="3" Fill="{DynamicResource TealBrush}"/>

    <!-- Footer -->
    <Border DockPanel.Dock="Bottom"
            BorderBrush="{DynamicResource MediumGrayBrush}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource LightGrayBrush}"
            Padding="20,12">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btn_cancel" Content="Annuleren"
                    Style="{DynamicResource SecondaryButton}"
                    Margin="0,0,8,0"/>
            <Button x:Name="btn_ok" Content="Update Parameters"
                    Style="{DynamicResource PrimaryButton}"/>
        </StackPanel>
    </Border>

    <!-- Content -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Filter Section -->
            <Border Background="{DynamicResource LightGrayBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Sheet Filter (optioneel)"
                               Style="{DynamicResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sheet numbers bevatten:"
                                   VerticalAlignment="Center"
                                   FontSize="13" Margin="0,0,12,0"/>
                        <TextBox x:Name="txt_filter" Width="350"
                                 Style="{DynamicResource StandardTextBox}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Two Column Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Sheet Parameters -->
                <Border Grid.Column="0" Background="{DynamicResource LightGrayBrush}"
                        CornerRadius="4" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Sheet Parameters"
                                   Style="{DynamicResource SectionHeader}"/>

                        <!-- Tekening Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_status" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Tekening Status:" VerticalAlignment="Center"
                                       Width="130" FontSize="13"/>
                            <ComboBox x:Name="combo_status" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- Sheet Issue Date -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_date" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Sheet Issue Date:" VerticalAlignment="Center"
                                       Width="130" FontSize="13"/>
                            <TextBox x:Name="txt_date" Width="200"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Tekening Schaal -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_schaal" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Tekening Schaal:" VerticalAlignment="Center"
                                       Width="130" FontSize="13"/>
                            <TextBox x:Name="txt_schaal" Width="200"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Tekening Fase -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <CheckBox x:Name="chk_fase" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Tekening Fase:" VerticalAlignment="Center"
                                       Width="130" FontSize="13"/>
                            <ComboBox x:Name="combo_fase" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- Wijzigingen Header -->
                        <TextBlock Text="Wijzigingen" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource VioletBrush}"
                                   Margin="0,0,0,8"/>

                        <!-- Wijziging A -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_a" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz A:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_a_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_a_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Wijziging B -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_b" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz B:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_b_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_b_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Wijziging C -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_c" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz C:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_c_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_c_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Wijziging D -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_d" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz D:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_d_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_d_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Wijziging E -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_e" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz E:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_e_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_e_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Wijziging F -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox x:Name="chk_wijz_f" VerticalAlignment="Center"
                                      Margin="0,0,6,0"/>
                            <TextBlock Text="Wijz F:" VerticalAlignment="Center"
                                       Width="50" FontSize="11"/>
                            <TextBlock Text="Datum:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_f_datum" Width="80" Margin="0,0,8,0"
                                     Style="{DynamicResource StandardTextBox}"/>
                            <TextBlock Text="Omschr:" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txt_wijz_f_omschr" Width="130"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- RIGHT COLUMN: Titleblock Parameters -->
                <Border Grid.Column="2" Background="{DynamicResource LightGrayBrush}"
                        CornerRadius="4" Padding="16" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Titleblock Parameters"
                                   Style="{DynamicResource SectionHeader}"/>

                        <!-- Standaard Schaal -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_std_schaal" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Standaard Schaal:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <ComboBox x:Name="combo_std_schaal" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- V Peil Zichtbaar -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_peil" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="V Peil Zichtbaar:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <ComboBox x:Name="combo_peil" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- Noordpijl Zichtbaar -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_noord" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Noordpijl Zichtbaar:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <ComboBox x:Name="combo_noord" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- Kenmerknummer -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_kenmerk" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Kenmerknummer:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <TextBox x:Name="txt_kenmerk" Width="80"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- Stempel -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_stempel" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Stempel:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <ComboBox x:Name="combo_stempel" Width="200"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                        <!-- Aantal Wijzigingen -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_aantal_wijz" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="Aantal wijzigingen:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <TextBox x:Name="txt_aantal_wijz" Width="80"
                                     Style="{DynamicResource StandardTextBox}"/>
                        </StackPanel>

                        <!-- 00_3BM_auteur -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="chk_00_auteur" VerticalAlignment="Center"
                                      Margin="0,0,8,0"/>
                            <TextBlock Text="00_3BM_auteur:" VerticalAlignment="Center"
                                       Width="140" FontSize="13"/>
                            <ComboBox x:Name="combo_00_auteur" Width="260"
                                      Style="{DynamicResource StandardComboBox}"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>

</DockPanel>
