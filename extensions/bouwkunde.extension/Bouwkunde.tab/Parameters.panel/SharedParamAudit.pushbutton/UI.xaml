<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Shared Parameter Audit"
    Width="900"
    Height="680"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="White">

    <Window.Resources>
        <!-- 3BM Huisstijl -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>

        <!-- TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{StaticResource LightGrayBrush}"
                                BorderThickness="0,0,0,3" BorderBrush="Transparent" Padding="16,10">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource TealBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style x:Key="AuditDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource MediumGrayBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MediumGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource LightGrayBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style x:Key="GridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource VioletBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#2A0B2A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock Text="Shared Parameter Audit"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"
                       Margin="20,16,20,4"/>
            <TextBlock x:Name="txt_subtitle" Text="Analyseer en beheer shared parameters"
                       FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource TealBrush}"
                       Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,10">
            <DockPanel>
                <TextBlock x:Name="txt_status"
                           Text="Klik 'Scan' om te beginnen"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btn_close" Content="Sluiten"
                            Padding="16,8"
                            Background="White"
                            Foreground="{StaticResource VioletBrush}"
                            BorderBrush="{StaticResource MediumGrayBrush}"
                            Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- TabControl -->
        <TabControl x:Name="tab_main" Margin="0" BorderThickness="0">

            <!-- ============================================ -->
            <!-- TAB 1: Ongebruikte Parameters                -->
            <!-- ============================================ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Ongebruikte Parameters" FontSize="13"/>
                </TabItem.Header>
                <DockPanel Margin="16">

                    <!-- Summary bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource LightGrayBrush}"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txt_summary"
                                       Text="Nog niet gescand"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Filter bar -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txt_filter_name"
                                 Grid.Column="0"
                                 Padding="8,6" FontSize="12"
                                 BorderBrush="{StaticResource MediumGrayBrush}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Filter op naam..."
                                                                       FontSize="12" Foreground="#AAAAAA"
                                                                       Margin="10,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ComboBox x:Name="cmb_filter_status"
                                  Grid.Column="2"
                                  Padding="8,6" FontSize="12"
                                  BorderBrush="{StaticResource MediumGrayBrush}"/>

                        <Button x:Name="btn_scan"
                                Grid.Column="4" Content="Scan"
                                Padding="16,6"
                                Background="{StaticResource TealBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Action bar -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Button x:Name="btn_select_orphans" Content="Selecteer orphans"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="{StaticResource YellowBrush}"
                                Foreground="{StaticResource VioletBrush}"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                FontSize="11" Cursor="Hand"/>
                        <Button x:Name="btn_select_all" Content="Selecteer alles"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="White"
                                Foreground="{StaticResource VioletBrush}"
                                BorderBrush="{StaticResource MediumGrayBrush}"
                                FontSize="11" Cursor="Hand"/>
                        <Button x:Name="btn_deselect_all" Content="Deselecteer"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="White"
                                Foreground="{StaticResource VioletBrush}"
                                BorderBrush="{StaticResource MediumGrayBrush}"
                                FontSize="11" Cursor="Hand"/>
                        <TextBlock x:Name="txt_selection_count"
                                   Text="" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                        <!-- Spacer -->
                        <Border Width="1" Background="Transparent" HorizontalAlignment="Stretch"/>
                        <Button x:Name="btn_delete" Content="Verwijder geselecteerde"
                                Padding="12,6" Margin="8,0,0,0"
                                Background="{StaticResource PeachBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                FontSize="11" Cursor="Hand"
                                IsEnabled="False"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid x:Name="grid_params"
                              Style="{StaticResource AuditDataGrid}"
                              ColumnHeaderStyle="{StaticResource GridColumnHeader}"/>

                </DockPanel>
            </TabItem>

            <!-- ============================================ -->
            <!-- TAB 2: Bestandsvergelijking                  -->
            <!-- ============================================ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Bestandsvergelijking" FontSize="13"/>
                </TabItem.Header>
                <DockPanel Margin="16">

                    <!-- File list panel -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource LightGrayBrush}"
                            CornerRadius="4" Padding="12" Margin="0,0,0,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Shared Parameter Bestanden (.txt)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource VioletBrush}"
                                       Margin="0,0,0,8"/>
                            <StackPanel DockPanel.Dock="Right" Margin="8,0,0,0">
                                <Button x:Name="btn_browse_spf" Content="Toevoegen..."
                                        Padding="12,6" Margin="0,0,0,4"
                                        Background="{StaticResource TealBrush}"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        FontSize="11" Cursor="Hand"/>
                                <Button x:Name="btn_remove_spf" Content="Verwijderen"
                                        Padding="12,6"
                                        Background="White"
                                        Foreground="{StaticResource VioletBrush}"
                                        BorderBrush="{StaticResource MediumGrayBrush}"
                                        FontSize="11" Cursor="Hand"/>
                            </StackPanel>
                            <ListBox x:Name="lst_spf_files"
                                     MinHeight="50" MaxHeight="100"
                                     FontSize="11"
                                     BorderBrush="{StaticResource MediumGrayBrush}"/>
                        </DockPanel>
                    </Border>

                    <!-- Summary bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource LightGrayBrush}"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                        <TextBlock x:Name="txt_compare_summary"
                                   Text="Voeg bestanden toe en klik 'Vergelijk'"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>

                    <!-- Filter bar -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txt_filter_compare"
                                 Grid.Column="0"
                                 Padding="8,6" FontSize="12"
                                 BorderBrush="{StaticResource MediumGrayBrush}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Filter op naam..."
                                                                       FontSize="12" Foreground="#AAAAAA"
                                                                       Margin="10,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ComboBox x:Name="cmb_filter_result"
                                  Grid.Column="2"
                                  Padding="8,6" FontSize="12"
                                  BorderBrush="{StaticResource MediumGrayBrush}"/>

                        <Button x:Name="btn_compare"
                                Grid.Column="4" Content="Vergelijk"
                                Padding="16,6"
                                Background="{StaticResource TealBrush}"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Action bar -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button x:Name="btn_export_csv" Content="Exporteer CSV"
                                Padding="12,6"
                                Background="White"
                                Foreground="{StaticResource VioletBrush}"
                                BorderBrush="{StaticResource MediumGrayBrush}"
                                FontSize="11" Cursor="Hand"
                                IsEnabled="False"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid x:Name="grid_compare"
                              Style="{StaticResource AuditDataGrid}"
                              ColumnHeaderStyle="{StaticResource GridColumnHeader}"/>

                </DockPanel>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
