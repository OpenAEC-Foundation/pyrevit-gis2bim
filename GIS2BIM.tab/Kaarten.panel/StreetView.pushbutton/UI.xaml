<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - Street View 360°"
    Width="520"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <!-- Kleuren -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="Street View 360°"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="Download Google Street View panorama (8 richtingen) en plaats op een sheet"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="Uitvoeren"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="LOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een projectlocatie in via de Locatie tool"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- API Key -->
                <TextBlock Text="GOOGLE API KEY"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Street View Static API key (wordt lokaal opgeslagen):"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox x:Name="txt_api_key" Width="340" Padding="8,6"
                             FontSize="12"/>
                    <Button x:Name="btn_save_key" Content="Opslaan"
                            Padding="12,6" Margin="8,0,0,0"
                            Background="{StaticResource LightGrayBrush}"
                            BorderBrush="{StaticResource MediumGrayBrush}"/>
                </StackPanel>

                <!-- Camera Instellingen -->
                <TextBlock Text="CAMERA INSTELLINGEN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <Border Background="{StaticResource LightGrayBrush}"
                        CornerRadius="3"
                        Padding="12"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="FOV:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmb_fov" Grid.Column="1" Padding="6,4" FontSize="12">
                            <ComboBoxItem Content="60°" Tag="60"/>
                            <ComboBoxItem Content="75°" Tag="75" IsSelected="True"/>
                            <ComboBoxItem Content="90°" Tag="90"/>
                            <ComboBoxItem Content="120°" Tag="120"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Pitch:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmb_pitch" Grid.Column="4" Padding="6,4" FontSize="12">
                            <ComboBoxItem Content="-20°" Tag="-20"/>
                            <ComboBoxItem Content="0°" Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="20°" Tag="20"/>
                        </ComboBox>

                        <TextBlock Grid.Column="6" Text="Pixels:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmb_image_size" Grid.Column="7" Padding="6,4" FontSize="12">
                            <ComboBoxItem Content="640 px" Tag="640"/>
                            <ComboBoxItem Content="1024 px" Tag="1024" IsSelected="True"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Beschikbare ruimte -->
                <TextBlock Text="BESCHIKBARE RUIMTE OP SHEET"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Maximale vrije ruimte voor de afbeeldingen (in mm):"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Breedte:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="txt_area_width" Width="60" Padding="6,4"
                             Text="380" FontSize="12"
                             HorizontalContentAlignment="Right"/>
                    <TextBlock Text="mm"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="4,0,20,0"/>
                    <TextBlock Text="Hoogte:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="txt_area_height" Width="60" Padding="6,4"
                             Text="210" FontSize="12"
                             HorizontalContentAlignment="Right"/>
                    <TextBlock Text="mm"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Sheet opties -->
                <TextBlock Text="SHEET"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Margin="0,0,0,8">
                    <RadioButton x:Name="rdo_new_sheet" Content="Nieuwe sheet aanmaken"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Margin="0,0,0,6"
                                 GroupName="SheetOption"/>
                    <RadioButton x:Name="rdo_existing_sheet" Content="Bestaande sheet gebruiken"
                                 IsChecked="True"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 GroupName="SheetOption"/>
                </StackPanel>

                <Border x:Name="pnl_existing_sheet"
                        Margin="20,0,0,16"
                        Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="Kies sheet:"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmb_existing_sheet"
                                  Padding="8,6"
                                  FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met laden..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
