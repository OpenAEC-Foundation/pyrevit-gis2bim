<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - BGT 3D Elementen"
    Width="480"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <!-- Kleuren -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="GIS2BIM - BGT 3D Elementen"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="Bomen en lantaarnpalen plaatsen vanuit BGT"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="Uitvoeren"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PROJECTLOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een projectlocatie in via de Locatie tool"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Zoekgebied -->
                <TextBlock Text="ZOEKGEBIED"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Straal:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_search_radius" Width="200" Padding="8,6">
                        <ComboBoxItem Content="50 m (100x100 m)" Tag="50"/>
                        <ComboBoxItem Content="100 m (200x200 m)" Tag="100" IsSelected="True"/>
                        <ComboBoxItem Content="200 m (400x400 m)" Tag="200"/>
                        <ComboBoxItem Content="500 m (1000x1000 m)" Tag="500"/>
                    </ComboBox>
                </StackPanel>

                <!-- Elementen -->
                <TextBlock Text="ELEMENTEN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Margin="0,0,0,16">
                    <CheckBox x:Name="chk_bomen"
                              Content="Bomen (BGT vegetatieobject)"
                              IsChecked="True"
                              Margin="0,0,0,6"
                              FontSize="13"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="chk_lantaarns"
                              Content="Lantaarnpalen (BGT paal / lichtmast)"
                              IsChecked="True"
                              Margin="0,0,0,6"
                              FontSize="13"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Families Selectie -->
                <TextBlock Text="REVIT FAMILIES"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bomen:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_family_bomen" Grid.Column="1"
                              Padding="8,6"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Lantaarns:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_family_lantaarns" Grid.Column="1"
                              Padding="8,6"/>
                </Grid>

                <TextBlock x:Name="txt_family_warning"
                           Text=""
                           FontSize="11"
                           Foreground="{StaticResource YellowBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,16"/>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met laden..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
