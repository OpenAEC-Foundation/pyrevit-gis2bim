<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - KLIC Laden"
    Width="520"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <!-- 3BM Kleuren -->
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="GIS2BIM - KLIC Laden"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="Kabels en Leidingen Informatie Centrum"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="KLIC Laden"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PROJECTLOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een projectlocatie in via de Locatie tool"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- KLIC Levering Selectie -->
                <TextBlock Text="KLIC LEVERING"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txt_klic_path"
                             Grid.Column="0"
                             Padding="8,6"
                             IsReadOnly="True"
                             Background="{StaticResource LightGrayBrush}"
                             BorderBrush="{StaticResource MediumGrayBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Selecteer een KLIC levering map of .zip..."/>
                    <Button x:Name="btn_browse"
                            Grid.Column="1"
                            Content="Bladeren"
                            Padding="12,6"
                            Margin="8,0,0,0"
                            Background="{StaticResource VioletBrush}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"/>
                </Grid>

                <!-- KLIC Info (na parsing) -->
                <Border x:Name="pnl_klic_info"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="LEVERING INFO"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="KLIC nr:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_klic_number" Grid.Row="0" Grid.Column="1"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Datum:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_klic_date" Grid.Row="1" Grid.Column="1"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Features:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,4"/>
                            <TextBlock x:Name="txt_klic_features" Grid.Row="2" Grid.Column="1"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Annotaties:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_klic_annotations" Grid.Row="3" Grid.Column="1"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Feature Type Checkboxes -->
                <StackPanel x:Name="pnl_features" Visibility="Collapsed">
                    <TextBlock Text="IMPORTEER"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_electricity"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#FF0000" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_electricity"
                                       Text="Elektriciteitskabel"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_telecom"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#008000" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_telecom"
                                       Text="Telecommunicatiekabel"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_gas"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#FFFF00" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_gas"
                                       Text="OlieGasChemicalienPijpleiding"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_sewer"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#8B5A2B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_sewer"
                                       Text="Rioolleiding"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_water"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#0000FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_water"
                                       Text="Waterleiding"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_duct"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#808080" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_duct"
                                       Text="Kabelbed / Mantelbuis"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chk_annotations"
                                      IsChecked="True"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="txt_annotations_chk"
                                       Text="Annotaties"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met laden..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
