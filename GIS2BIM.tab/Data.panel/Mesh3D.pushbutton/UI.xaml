<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - 3D Mesh Importeren"
    Width="560"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="GIS2BIM - 3D Mesh Importeren"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="OBJ / Google 3D Tiles als DirectShape"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="Mesh Importeren"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PROJECTLOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een locatie in via de Locatie tool (nodig voor Google 3D en RD-modus)."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Bron selectie -->
                <TextBlock Text="BRON"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Margin="0,0,0,16">
                    <RadioButton x:Name="rdo_source_file"
                                 Content="OBJ bestand (Kavel10, Blender, etc.)"
                                 GroupName="source"
                                 IsChecked="True"
                                 Margin="0,0,0,6"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                    <RadioButton x:Name="rdo_source_google"
                                 Content="Google 3D Tiles (vereist API key)"
                                 GroupName="source"
                                 Margin="0,0,0,6"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- ============================================ -->
                <!-- OBJ BESTAND OPTIES -->
                <!-- ============================================ -->
                <StackPanel x:Name="pnl_file_options">

                    <!-- Bestand selectie -->
                    <TextBlock Text="OBJ BESTAND"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txt_filepath" Grid.Column="0"
                                 Padding="8,6"
                                 IsReadOnly="True"
                                 Background="{StaticResource LightGrayBrush}"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                        <Button x:Name="btn_browse" Grid.Column="1"
                                Content="Bladeren..."
                                Padding="12,6"
                                Margin="8,0,0,0"
                                Background="White"
                                BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Bestand info -->
                    <Border x:Name="pnl_file_info"
                            Background="{StaticResource LightGrayBrush}"
                            Padding="12"
                            CornerRadius="3"
                            Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="BESTANDSINFO"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource VioletBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="txt_file_info"
                                       Text="-"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Coordinaten modus -->
                    <TextBlock Text="COORDINATEN"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,16">
                        <RadioButton x:Name="rdo_coords_rd"
                                     Content="RD-coordinaten (EPSG:28992) - Nederlandse GIS data"
                                     GroupName="coords"
                                     IsChecked="True"
                                     Margin="0,0,0,6"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rdo_coords_local"
                                     Content="Lokaal - Mesh origin op project origin plaatsen"
                                     GroupName="coords"
                                     Margin="0,0,0,6"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Eenheid -->
                    <TextBlock Text="EENHEID"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ComboBox x:Name="cmb_unit" Width="180" Padding="8,6">
                            <ComboBoxItem Content="Meters" Tag="1.0" IsSelected="True"/>
                            <ComboBoxItem Content="Centimeters" Tag="0.01"/>
                            <ComboBoxItem Content="Millimeters" Tag="0.001"/>
                            <ComboBoxItem Content="Feet" Tag="0.3048"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Opties -->
                    <TextBlock Text="OPTIES"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <CheckBox x:Name="chk_per_object"
                              Content="Per object splitsen (individueel selecteerbaar)"
                              IsChecked="False"
                              FontSize="13"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,6"/>

                    <CheckBox x:Name="chk_use_materials"
                              Content="Kleuren uit MTL bestand toepassen"
                              IsChecked="True"
                              FontSize="13"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,16"/>

                </StackPanel>

                <!-- ============================================ -->
                <!-- GOOGLE 3D TILES OPTIES -->
                <!-- ============================================ -->
                <StackPanel x:Name="pnl_google_options" Visibility="Collapsed">

                    <!-- API Key -->
                    <TextBlock Text="GOOGLE API KEY"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txt_api_key"
                             Padding="8,6"
                             Margin="0,0,0,4"
                             Background="{StaticResource LightGrayBrush}"
                             BorderBrush="{StaticResource MediumGrayBrush}"/>
                    <TextBlock Text="Map Tiles API moet ingeschakeld zijn in Google Cloud Console"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Zoekgebied -->
                    <TextBlock Text="ZOEKGEBIED"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Radius:"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,12,0"/>
                        <ComboBox x:Name="cmb_google_radius" Width="180" Padding="8,6">
                            <ComboBoxItem Content="50 m (klein)" Tag="50"/>
                            <ComboBoxItem Content="100 m" Tag="100" IsSelected="True"/>
                            <ComboBoxItem Content="200 m" Tag="200"/>
                            <ComboBoxItem Content="500 m (groot)" Tag="500"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Detail -->
                    <TextBlock Text="DETAILNIVEAU"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource VioletBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,16">
                        <RadioButton x:Name="rdo_detail_low"
                                     Content="Laag - Snel, minder detail (geometric error 50)"
                                     GroupName="detail"
                                     Margin="0,0,0,6"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rdo_detail_medium"
                                     Content="Gemiddeld - Balans snelheid/detail (geometric error 20)"
                                     GroupName="detail"
                                     IsChecked="True"
                                     Margin="0,0,0,6"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rdo_detail_high"
                                     Content="Hoog - Meeste detail, meer tiles (geometric error 5)"
                                     GroupName="detail"
                                     Margin="0,0,0,6"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                </StackPanel>

                <!-- Info -->
                <Border Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <TextBlock x:Name="txt_info"
                               Text="Importeer 3D meshes als DirectShape (GenericModel). OBJ: vanuit Kavel10, Blender, etc. Google 3D: fotogrammetrische meshes rechtstreeks van Google (geometry without textures)."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met laden..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
