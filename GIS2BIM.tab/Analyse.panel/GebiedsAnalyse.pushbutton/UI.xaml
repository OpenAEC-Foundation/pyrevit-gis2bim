<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIS2BIM - Gebiedsanalyse"
    Width="560"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Window.Resources>
        <SolidColorBrush x:Key="VioletBrush" Color="#350E35"/>
        <SolidColorBrush x:Key="TealBrush" Color="#45B6A8"/>
        <SolidColorBrush x:Key="YellowBrush" Color="#EFBD75"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#DB4C40"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#323232"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Background="{StaticResource VioletBrush}">
            <TextBlock
                Text="GIS2BIM - Gebiedsanalyse"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Margin="20,16,20,4"/>
            <TextBlock
                x:Name="txt_subtitle"
                Text="Voorzieningenwaarde op basis van OpenStreetMap"
                FontSize="12"
                FontWeight="Medium"
                Foreground="{StaticResource TealBrush}"
                Margin="20,0,20,16"/>
        </StackPanel>

        <!-- Accent Line -->
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource TealBrush}"/>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource MediumGrayBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource LightGrayBrush}"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btn_cancel" Content="Annuleren"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="White"
                        BorderBrush="{StaticResource MediumGrayBrush}"/>
                <Button x:Name="btn_execute" Content="Analyse starten"
                        Padding="20,8"
                        Background="{StaticResource TealBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Locatie Info -->
                <Border x:Name="pnl_location"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PROJECTLOCATIE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource VioletBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RD X:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="txt_location_x" Grid.Column="1" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="RD Y:"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,12,0"/>
                            <TextBlock x:Name="txt_location_y" Grid.Column="3" Text="-"
                                       Foreground="{StaticResource TealBrush}" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Waarschuwing geen locatie -->
                <Border x:Name="pnl_no_location"
                        Background="#FFF3E0"
                        Padding="12"
                        CornerRadius="3"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GEEN LOCATIE INGESTELD"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PeachBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Stel eerst een projectlocatie in via de Locatie tool"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Preset -->
                <TextBlock Text="PRESET"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Type:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_preset" Width="180" Padding="8,6">
                        <ComboBoxItem Content="Woningbouw" Tag="Woningbouw" IsSelected="True"/>
                        <ComboBoxItem Content="Kantoor" Tag="Kantoor"/>
                        <ComboBoxItem Content="Aangepast" Tag="custom"/>
                    </ComboBox>
                </StackPanel>

                <!-- Categorieen -->
                <TextBlock Text="VOORZIENINGEN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <StackPanel Margin="0,0,0,16">
                    <!-- Kolomkoppen -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Categorie"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Max bereik"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Gewicht"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- School -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_school" Grid.Column="0"
                                  Content="School / onderwijs"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_school" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000" IsSelected="True"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_school" Grid.Column="2"
                                 Text="1.0" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Bus -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_bus" Grid.Column="0"
                                  Content="Bushalte"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_bus" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500" IsSelected="True"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_bus" Grid.Column="2"
                                 Text="0.5" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Trein -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_trein" Grid.Column="0"
                                  Content="Treinstation"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_trein" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000" IsSelected="True"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_trein" Grid.Column="2"
                                 Text="1.0" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Park -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_park" Grid.Column="0"
                                  Content="Park / groen"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_park" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000" IsSelected="True"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_park" Grid.Column="2"
                                 Text="0.5" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Supermarkt -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_supermarkt" Grid.Column="0"
                                  Content="Supermarkt / winkels"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_supermarkt" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000" IsSelected="True"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_supermarkt" Grid.Column="2"
                                 Text="0.75" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Ziekenhuis -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_ziekenhuis" Grid.Column="0"
                                  Content="Ziekenhuis"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_ziekenhuis" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000" IsSelected="True"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_ziekenhuis" Grid.Column="2"
                                 Text="0.75" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <!-- Huisarts -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="chk_huisarts" Grid.Column="0"
                                  Content="Huisarts"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmb_rings_huisarts" Grid.Column="1"
                                  Padding="4,3" FontSize="11" Margin="4,0"
                                  BorderBrush="{StaticResource MediumGrayBrush}">
                            <ComboBoxItem Content="500 m" Tag="500"/>
                            <ComboBoxItem Content="1.000 m" Tag="1000"/>
                            <ComboBoxItem Content="2.000 m" Tag="2000" IsSelected="True"/>
                            <ComboBoxItem Content="5.000 m" Tag="5000"/>
                        </ComboBox>
                        <TextBox x:Name="txt_weight_huisarts" Grid.Column="2"
                                 Text="0.5" Padding="4,2"
                                 HorizontalAlignment="Right" Width="55"
                                 BorderBrush="{StaticResource MediumGrayBrush}"/>
                    </Grid>

                    <TextBlock Text="Bereik = maximale afstand tot voorziening | Gewicht = belang (0.0 - 1.0)"
                               FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Grid instellingen -->
                <TextBlock Text="GRID INSTELLINGEN"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource VioletBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gebiedsgrootte:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmb_grid_size" Grid.Row="0" Grid.Column="1"
                              Padding="8,6">
                        <ComboBoxItem Content="1000 x 1000 m" Tag="1000"/>
                        <ComboBoxItem Content="2000 x 2000 m" Tag="2000" IsSelected="True"/>
                        <ComboBoxItem Content="3000 x 3000 m" Tag="3000"/>
                        <ComboBoxItem Content="5000 x 5000 m" Tag="5000"/>
                    </ComboBox>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Resolutie:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="24,0,12,0"/>
                    <ComboBox x:Name="cmb_resolution" Grid.Row="0" Grid.Column="3"
                              Padding="8,6">
                        <ComboBoxItem Content="25 m" Tag="25"/>
                        <ComboBoxItem Content="50 m" Tag="50" IsSelected="True"/>
                        <ComboBoxItem Content="100 m" Tag="100"/>
                        <ComboBoxItem Content="200 m" Tag="200"/>
                    </ComboBox>

                    <CheckBox x:Name="chk_smoothing" Grid.Row="2" Grid.Column="0"
                              Grid.ColumnSpan="4"
                              Content="Gaussian smoothing toepassen (3x3 kernel)"
                              IsChecked="True" FontSize="12"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                </Grid>

                <!-- Status/Progress -->
                <Border x:Name="pnl_progress"
                        Background="{StaticResource LightGrayBrush}"
                        Padding="12"
                        CornerRadius="3"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txt_progress"
                                   Text="Bezig met analyse..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ProgressBar x:Name="progress_bar"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status/Error -->
                <TextBlock x:Name="txt_status"
                           Text=""
                           FontSize="12"
                           Foreground="{StaticResource PeachBrush}"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
