    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import sys\r\nsys.path.append(\"C:\\Program Files (x86)\\IronPython 2.7\\Lib\")\r\n\r\nimport clr\r\nimport re\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nimport xml.etree.ElementTree as ET\r\n\r\ndef BGTgetHoofdMembers():\r\n    return Path.split(\"\\\\\")[-1].replace(\".gml\",\"\").replace(\"bgt_\",\"\").capitalize()\r\n\r\ndef BGTGetUniqueMembers(HoofdMember):\r\n    Types=[]\r\n    for CityObjectMember in Root.iter('{http://www.geostandaarden.nl/imgeo/2.1}'+ HoofdMember):\r\n        try:\r\n            Type = CityObjectMember.find('{http://www.geostandaarden.nl/imgeo/2.1}plus-type').text\r\n            if Type not in Types:\r\n                Types.append(Type)\r\n        except:\r\n            continue\r\n    return Types\r\n\r\ndef BGTFilter(HoofdMember, SubMember):\r\n    MemberPositions=[]\r\n    Count = 0\r\n    for CityObjectMember in Root.iter('{http://www.geostandaarden.nl/imgeo/2.1}'+ HoofdMember):\r\n        try:\r\n            Type = CityObjectMember.find('{http://www.geostandaarden.nl/imgeo/2.1}plus-type').text\r\n            if Type == SubMember:\r\n                Count +=1\r\n                try:\r\n                    Position = CityObjectMember.find('{http://www.geostandaarden.nl/imgeo/2.1}geometrie2d' + HoofdMember + '/{http://www.opengis.net/gml}Point/').text\r\n                    RDCoordinates = Position.split(\" \")\r\n                    #print(\"type: {} / RDX: {} - RDY: {}\".format(Type, RDCoordinates[1],RDCoordinates[0]))\r\n                    MemberPositions.append(RDCoordinates)\r\n                except:\r\n                    continue\r\n                    #print(\"niet gevonden\")\r\n        except:\r\n            continue\r\n            #print(\"paal heeft geen type\")\r\n    #print('aantal gevonden: {}'.format(Count))\r\n    return MemberPositions\r\n\r\ndef PointsInBoundingBox(rdx, rdy, bb_size, points):\r\n    # Bounding box definition\r\n    PointsInBbox = []\r\n    BbSizeHalf = bb_size/2\r\n    min_x = rdx - BbSizeHalf\r\n    min_y = rdy - BbSizeHalf\r\n    max_x = rdx + BbSizeHalf\r\n    max_y = rdy + BbSizeHalf\r\n    for point in ListToFloat(points):\r\n        if point[0] > min_x and point [0] < max_x:\r\n            print(\"point fits in bbox on the x\")\r\n            if point[1] > min_y and point [1] < max_y:\r\n                print(\"Point also fits in bbox on the y\")\r\n                PointsInBbox.append(point)\r\n    return PointsInBbox\r\n \r\ndef ListToFloat(lst):\r\n    for inner in lst:\r\n    \tfor index, string in enumerate(inner):\r\n        \tinner[index] = float(string)\r\n    return lst  \r\n\r\ndef TransformPoints(rdx, rdy, points, scale):\r\n    PointRelative=[]\r\n    for point in ListToFloat(points):\r\n        x = (point[0]-rdx) * scale\r\n        y = (point[1]-rdy) * scale\r\n        PointRelative.append([x,y])\r\n    return PointRelative  \r\n\r\nPath = IN[0]\r\nTree = ET.parse(Path)\r\nRoot = Tree.getroot()\r\n\r\nrdx = IN[1]\r\nrdy = IN[2] \r\nbbox = IN[3]\r\nSubType = IN[4]\r\n\r\npointsrdxrdy = PointsInBoundingBox(rdx, rdy, bbox, BGTFilter(\"Paal\", SubType))\r\npointsout = TransformPoints(rdx, rdy, pointsrdxrdy, 1000)\r\n\r\nOUT = pointsout",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "b1a2b8835da943b7aba133b6d39a1cbc",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "46463647fc9c4d2caa27911f2830d2ed",
