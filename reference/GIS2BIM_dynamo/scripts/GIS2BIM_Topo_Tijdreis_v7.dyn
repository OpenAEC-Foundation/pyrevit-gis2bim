    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nimport os\r\nlocalapp = os.getenv(r'LOCALAPPDATA')\r\nsys.path.append(os.path.join(localapp, r'python-3.9.12-embed-amd64\\Lib\\site-packages'))\r\n\r\nimport requests\r\nimport xmltodict\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ntimelineLayers = IN[0]\r\n\r\n# Function wrapper for automatic lacing\r\ndef getLevelsForLayer(timelineLayer):\r\n    # STEP 1: Download Capabilites XML\r\n    \r\n    URL_TEMPLATE = \"https://tiles.arcgis.com/tiles/nSZVuSZjHpEZZbRo/arcgis/rest/services/{layer}/MapServer/WMTS/1.0.0/WMTSCapabilities.xml\"\r\n    \r\n    url = URL_TEMPLATE.format(layer = timelineLayer)\r\n    xml = requests.get(url).content\r\n    \r\n    data = xmltodict.parse(xml)\r\n    \r\n    \r\n    # STEP 2: Parse Capabilities\r\n    tileMatrices = data['Capabilities']['Contents']['TileMatrixSet']['TileMatrix']\r\n    \r\n    pixelSize = 0.00028 # meter per pixel\r\n    \r\n    zoomLevels = []\r\n    for tileMatrix in tileMatrices:\r\n        \r\n        identifier = tileMatrix['ows:Identifier']\r\n        scaleDenominator = float(tileMatrix['ScaleDenominator'])\r\n        rowOrigin = float(tileMatrix['TopLeftCorner'].split(' ')[1])\r\n        columnOrigin = float(tileMatrix['TopLeftCorner'].split(' ')[0])\r\n        tileWidth = int(tileMatrix['TileWidth'])\r\n        tileHeight = int(tileMatrix['TileHeight'])\r\n        matrixWidth = int(tileMatrix['MatrixWidth'])\r\n        matrixHeight = int(tileMatrix['MatrixHeight'])\r\n        \r\n        # calculate additional attributes\r\n        tileResolution = pixelSize * scaleDenominator\r\n        tileContentSize = tileWidth * tileResolution\r\n        \r\n        zoomLevel = {\r\n            'identifier': identifier,\r\n            'scaleDenominator': scaleDenominator,\r\n            'rowOrigin': rowOrigin,\r\n            'columnOrigin': columnOrigin,\r\n            'tileWidth': tileWidth,\r\n            'tileHeight': tileHeight,\r\n            'matrixWidth': matrixWidth,\r\n            'matrixHeight': matrixHeight,\r\n            'resolution': tileResolution,\r\n            'tileContentSize': tileContentSize,\r\n        }\r\n        \r\n        zoomLevels.append(zoomLevel)\r\n        \r\n    return zoomLevels\r\n    \r\nif type(timelineLayers) == list:\r\n    layerLevels = []\r\n    for layer in timelineLayers:\r\n        layerLevels.append(getLevelsForLayer(layer))\r\nelse:\r\n    layerLevels = getLevelsForLayer(timelineLayers)\r\n\r\n# STEP 3: Return Zoom Levels\r\nOUT = layerLevels\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "ffe92d4038f84359afa2366fa03b843c",
      "NodeType": "PythonScriptNode",
      "Inputs": [
