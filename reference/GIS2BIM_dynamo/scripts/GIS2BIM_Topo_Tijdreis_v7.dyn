    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nimport math\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\nbboxMin = IN[0]\r\nbboxMax = IN[1]\r\nimageWidth = IN[2]\r\nimageHeight = IN[3]\r\nimageCount = IN[4]\r\ngapDistanceh = IN[5]\r\ngapDistancev = IN[6]\r\nshiftX = IN[7]\r\nshiftY = IN[8]\r\nminFrame = IN[9]\r\n\r\nframeWidth = abs(bboxMax.X - bboxMin.X)\r\nframeHeight = abs(bboxMax.Y - bboxMin.Y)\r\n\r\nmaxItemsPerRow = math.floor((frameWidth - 2 * minFrame + gapDistanceh) / (imageWidth + gapDistanceh))\r\nmaxItemsPerCol = math.floor((frameHeight - 2 * minFrame + gapDistancev) / (imageHeight + gapDistancev))\r\n\r\nrowCount = min(maxItemsPerCol, math.ceil(imageCount / maxItemsPerRow))\r\ncolCount = min(maxItemsPerRow, math.ceil(imageCount / maxItemsPerCol))\r\n\r\ncontentWidth = colCount * imageWidth + (colCount - 1) * gapDistanceh\r\ncontentHeight = rowCount * imageHeight + (rowCount - 1) * gapDistancev\r\n\r\nactualFrameWidth = (frameWidth - contentWidth) / 2\r\nactualFrameHeight = (frameHeight - contentHeight) / 2\r\n\r\npositionsX = []\r\npositionsY = []\r\ncurrentRow = 0\r\ncurrentCol = 0\r\nfor i in range(imageCount):\r\n    x = actualFrameWidth + currentCol * (imageWidth + gapDistanceh) + imageWidth / 2\r\n    y = actualFrameHeight + currentRow * (imageHeight + gapDistanceh) + imageHeight / 2\r\n    \r\n    positionsX.append(x + bboxMin.X + shiftX)\r\n    positionsY.append(bboxMax.Y - y + shiftY)\r\n    \r\n    currentCol += 1\r\n    \r\n    if currentCol >= maxItemsPerRow:\r\n        currentCol = 0\r\n        currentRow += 1\r\n        \r\n    if currentRow >= maxItemsPerCol:\r\n        break\r\n \r\nOUT = [positionsX, positionsY]\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "82c533cfc245457e9e9310eadb3bfc68",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "df881e2701774e29a91dc4ee8cdf09cf",
