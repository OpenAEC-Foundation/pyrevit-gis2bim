      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "[\"2006\",\n\"2007\",\n\"2008\",\n\"2009\",\n\"2010\",\n\"2011\",\n\"2012\",\n\"2013\",\n\"2014\",\n\"2015\",\n\"2016\",\n\"2017\",\n\"2018\",\n\"2019\",\n\"2020\",\n\"2021\",\n\"2022\"];"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport os\r\nlocalapp = os.getenv(r'LOCALAPPDATA')\r\nsys.path.append(os.path.join(localapp, r'python-3.9.12-embed-amd64\\Lib\\site-packages'))\r\nimport re\r\nimport requests\r\nimport xmltodict\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ntimelineLayers = IN[0]\r\n\r\n# Function wrapper for automatic lacing\r\ndef getLevelsForLayer(timelineLayer):\r\n    \r\n    # STEP 1: Download Capabilites XML\r\n    URL_TEMPLATE = \"https://tiles.arcgis.com/tiles/nSZVuSZjHpEZZbRo/arcgis/rest/services/{layer}/MapServer/WMTS/1.0.0/WMTSCapabilities.xml\"\r\n    \r\n    url = URL_TEMPLATE.format(layer = timelineLayer)\r\n    xml = requests.get(url).content\r\n    \r\n    data = xmltodict.parse(xml)\r\n    \r\n    # STEP 2: Parse Capabilities\r\n    templateURL = data['Capabilities']['Contents']['Layer']['ResourceURL']['@template']\r\n    defaultStyle = data['Capabilities']['Contents']['Layer']['Style']['ows:Identifier']\r\n    tileMatrixSet = data['Capabilities']['Contents']['Layer']['TileMatrixSetLink']['TileMatrixSet']    \r\n      \r\n    # print('URL', templateURL, defaultStyle, tileMatrixSet)\r\n    \r\n    templateURL = re.sub('{Style}', defaultStyle, templateURL)\r\n    templateURL = re.sub('{TileMatrixSet}', tileMatrixSet, templateURL)\r\n    \r\n    # print('URL', templateURL, defaultStyle, tileMatrixSet)\r\n    \r\n    return templateURL\r\n    \r\nif type(timelineLayers) == list:\r\n    layerTemplates = []\r\n    for layer in timelineLayers:\r\n        layerTemplates.append(getLevelsForLayer(layer))\r\nelse:\r\n    layerTemplates = getLevelsForLayer(timelineLayers)\r\n\r\n# STEP 3: Return Zoom Levels\r\nOUT = layerTemplates\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "243658d3da8644f09cf5cd20b628fa85",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "857f89d50d7d4e41a8432a9805a88731",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "959dd0e9cb954ab394361f8cec8cff40",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
