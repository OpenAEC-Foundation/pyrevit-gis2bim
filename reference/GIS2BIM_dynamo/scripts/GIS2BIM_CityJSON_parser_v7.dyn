    {
      "ConcreteType": "DSRevitNodesUI.Categories, DSRevitNodesUI",
      "SelectedIndex": 267,
      "SelectedString": "OST_GenericModel",
      "Id": "77836f66af454d1bbab24fcc5c79b684",
      "NodeType": "ExtensionNode",
      "Inputs": [],
