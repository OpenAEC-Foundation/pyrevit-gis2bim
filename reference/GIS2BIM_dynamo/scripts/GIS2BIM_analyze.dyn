    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Enable Python support and load DesignScript library\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport numpy as np\r\n\r\n# inputs\r\ndataEnteringNode = IN\r\naLegend = IN[3]\r\naLegendOmschrijvingen = []\r\niMaxValueAdition = float(IN[4])\r\n#aImagePixelColors = []\r\n\r\n#functions\r\n\r\ndef flatten_extend(matrix):\r\n    flat_list = []\r\n    for row in matrix:\r\n        flat_list.extend(row)\r\n    return flat_list\r\n\r\ndef CombineRGB():\r\n    aImagePixelColors = [] \r\n    aImagePixelColorsr = IN[0]\r\n    aImagePixelColorsg = IN[1]\r\n    aImagePixelColorsb = IN[2]\r\n    for index, r in enumerate(aImagePixelColorsr):\r\n        g=aImagePixelColorsg[index]\r\n        b=aImagePixelColorsb[index]\r\n        aImagePixelColors.append([r,g,b])\r\n    #print(aImagePixelColors)\r\n    return aImagePixelColors\r\n    \r\ndef closest(colors,color, aValues):\r\n    colors = np.array(colors)\r\n    aValues = np.array(aValues)\r\n    color = np.array(color)\r\n    distances = np.sqrt(np.sum((colors-color)**2,axis=1))\r\n    index_of_smallest = np.where(distances==np.amin(distances))\r\n    smallest_distance = colors[index_of_smallest]\r\n    iValues = float(aValues[index_of_smallest][0])\r\n    return iValues \r\n               \r\ndef CheckImageColors():\r\n    aLegendColors = []\r\n    aValues = np.arange(0, iMaxValueAdition, iMaxValueAdition/len(aLegend)).tolist()\r\n    aValues.reverse()\r\n    #maak eerst twee lists van de legend\r\n    for item in aLegend:\r\n        iLegendColor= item[0]\r\n        aLegendColors.append(iLegendColor)\r\n        sLegendomschrijving = item[1]\r\n        aLegendOmschrijvingen.append(sLegendomschrijving)\r\n    #print(aLegendColors)\r\n    #maak een lijst met de rgb waarde per punt in de afbeelding\r\n    aImagePixelColors = CombineRGB()\r\n    aValuePerPoint = []\r\n    for iColor in aImagePixelColors:\r\n        #print(iColor)\r\n        iValue=closest(aLegendColors,iColor,aValues)\r\n        aValuePerPoint.append(iValue)\r\n\r\n    return aValuePerPoint\r\n        \r\nOutput = CheckImageColors()\r\n    \t\r\n#outputs\r\nOUT = Output",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "16c67f7f62734540bd58daf3c8dc8dd7",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "d246e34ea78244d6b95769dea09ce4b2",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "30e4df37fb7a4f378448137a63fdca95",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a27ed95762f247d0985d468c033cd70d",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
