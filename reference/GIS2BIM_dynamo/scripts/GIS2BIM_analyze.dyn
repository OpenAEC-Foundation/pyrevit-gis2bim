    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport math\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ndataEnteringNode = IN\r\n\r\nRDX=IN[0]\r\nRDY=IN[1]\r\nRevitPoints = IN[2]\r\nPoiPoints = IN[3]\r\nextravalue = 0.5\r\n# Place your code below this line\r\n    \r\ndef is_inside_a_circle(point, circles):\r\n    for circle in circles:\r\n        if (point[0]-circle[0])**2 + (point[1]-circle[1])**2 < circle[2]**2:\r\n            return extravalue\r\n    return 0\r\n\r\ndef TransformPointToRD(point):\r\n    x=point.X\r\n    y=point.Y\r\n    pointRDX=x+RDX*1000\r\n    pointRDY=y+RDY*1000\r\n    PointCoordinateRD=[pointRDX,pointRDY]\r\n    return PointCoordinateRD\r\n\r\ncircles = []\r\nfor PoiPoint in PoiPoints:\r\n    #letop dirty functie de z value wordt misbruikt voor de radius\r\n    circle=[PoiPoint.X,PoiPoint.Y,PoiPoint.Z*1000]\r\n    circles.append(circle)\r\n\r\nvalues = []  \r\nfor point in RevitPoints:\r\n    point=[point.X,point.Y]\r\n    values.append(is_inside_a_circle(point, circles))\r\n\r\n# Assign your output to the OUT variable.\r\nOUT = values",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "ceb70fadaa7a4328a678634ac3462b53",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "efaca5b81b454f95bfa22733498053f2",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "20eea5e80daa419997599be910aab2ad",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "12ae4142495543d39cbb8f10d12ee19f",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
