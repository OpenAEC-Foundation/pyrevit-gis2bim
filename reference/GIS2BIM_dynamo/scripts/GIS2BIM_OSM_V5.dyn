    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "0ecf1459dd17429a9f2f0950d55242f8",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        {
          "Id": "6b92c2007ed64ea58b4efc6370b2b0d4",
          "Name": "bbox",
          "Description": "bbox",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "1b768707dc34440891e94859086f9095",
          "Name": "targetEPSG",
          "Description": "targetEPSG",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "79cc10e3c2cb42549e0441dc359b24ee",
          "Name": "",
          "Description": "Value of expression at line 1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d19342c3e6c64d56b1b18347fafb0fcf",
          "Name": "",
          "Description": "Value of expression at line 2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "bbox;\ntargetEPSG;"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nfrom urllib.request import Request, urlopen\r\nimport json\r\nimport re\r\n\r\n\r\n# INPUT PARAMETERS\r\nbbox = IN[0]\r\ntargetEPSG = IN[1]\r\n\r\n\r\n# GOBALS\r\nWSG84_EPSG = 4326 \r\n\r\n\r\n# FUNCTIONS\r\ndef transformEPSG(source, target, x, y):\r\n    convUrl = \"http://epsg.io/trans?&s_srs={source}&t_srs={target}&x={x}&y={y}&format=json&trans=1\".format(source=source, target=target, x=x, y=y)\r\n    try:\r\n        request = Request(convUrl)\r\n        # Add some credibility to our request\r\n        request.add_header('user-agent', 'Revit Dynamo')\r\n        convResponse = urlopen(request)\r\n        convData = json.loads(convResponse.read())\r\n        return [convData['x'], convData['y']]\r\n    except Exception as error:\r\n        print('ERROR transforming coordinates:', error)\r\n        return [x, y]\r\n        \r\ndef extractType(tags):\r\n    keys = tags.keys()\r\n    if 'subway' in keys and tags['subway'] == 'yes':\r\n        return 'subway'\r\n    if 'tram' in keys and tags['tram'] == 'yes':\r\n        return 'tram'\r\n    if 'bus' in keys and tags['bus'] == 'yes':\r\n        return 'bus'        \r\n\r\ndef extractLocation(lat, lon):\r\n   return transformEPSG(WSG84_EPSG, targetEPSG, lon, lat)\r\n\r\n\r\n# SCRIPT\r\n# Step 1: Translate BBox to WSG84 Sperical\r\nbboxElements = bbox.split(',')\r\nbboxWSG84Start = transformEPSG(targetEPSG, WSG84_EPSG, bboxElements[0], bboxElements[1])\r\nbboxWSG84End = transformEPSG(targetEPSG, WSG84_EPSG, bboxElements[2], bboxElements[3])\r\nbboxWSG84 = \"{xMin},{yMin},{xMax},{yMax}\".format(xMin=bboxWSG84Start[1],yMin=bboxWSG84Start[0],xMax=bboxWSG84End[1],yMax=bboxWSG84End[0])\r\n\r\n\r\n# Step 2: Construct Query\r\nquery = '[out:json];(node[\"public_transport\"=\"stop_position\"]({bbox});node[\"public_transport\"=\"platform\"]({bbox}););out;'.format(bbox=bboxWSG84)\r\n\r\n\r\n# Step 3: Construct URL and make request\r\nurl = 'https://z.overpass-api.de/api/interpreter?data={query}'.format(query=query)\r\n\r\nprint('OVERPASS URL', url)\r\n\r\nrequest = Request(url)\r\nrequest.add_header('user-agent', 'Revit Dynamo')\r\nresponse = urlopen(request)\r\n\r\ndata = json.loads(response.read())\r\n\r\n\r\n# Step 4: Parse Data and Transform Back to Target EPSG\r\nstations = []\r\nnodes = data['elements']\r\nfor node in nodes:\r\n\r\n    if 'name' not in node['tags'].keys():\r\n        continue\r\n    \r\n    name = node['tags']['name']\r\n    type = extractType(node['tags'])\r\n    location = extractLocation(node['lat'], node['lon'])\r\n    \r\n    if not type:\r\n        continue\r\n\r\n    # Skip Duplicate stations/platforms\r\n    exists = False;\r\n    for station in stations:\r\n        if station['name'] == name and station['type'] == type:\r\n            exists = True\r\n            break\r\n            \r\n    if exists:\r\n        continue\r\n            \r\n    stations.append({\r\n        'name': name,\r\n        'location': location,\r\n        'type': type,\r\n    })\r\n \r\n\r\n# OUTPUT\r\nOUT = stations\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "d08500363faa4cfc80ed8cdb11f7edd5",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "5a47db92bfc84f799fbd72c4c1f303ec",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "85777893c145457f956c855c1b7e68d1",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "6272308d04834f509747f39ba8ebad92",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
