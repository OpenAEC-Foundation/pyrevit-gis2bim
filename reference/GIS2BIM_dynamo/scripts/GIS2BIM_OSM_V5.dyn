      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "PLocationX;\nPLocationY;\nScaleFactor = 1000;\nStationRadii = {\n\t\"bus\": 150,\n\t\"subway\": 250,\n\t\"tram\": 200,\n\t\"other\": 150\n};\nStationMaterials = {\n\t\"bus\": \"MLA_green\",\n\t\"subway\": \"MLA_blue\",\n\t\"tram\": \"MLA_yellow\",\n\t\"other\": \"MLA_gray\"\n};"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\nstations = IN[0]\r\ncenterX = IN[1]\r\ncenterY = IN[2]\r\nscaleFactor = IN[3]\r\nstationRadii = IN[4]\r\nstationMaterials = IN[5]\r\n\r\n# Place your code below this line\r\n\r\navailableStationRadii = stationRadii.keys()\r\ndef getStationRadius(type):\r\n    if type in availableStationRadii:\r\n        return stationRadii[type]\r\n    else:\r\n        return stationRadii['other']\r\n\r\navailableMaterials = stationMaterials.keys()\r\ndef getStationMaterial(type):\r\n    if type in availableMaterials:\r\n        return stationMaterials[type]\r\n    else:\r\n        return stationMaterials['other']\r\n    \r\n\r\npoints = []\r\ncircles = []\r\nboundaries = []\r\nnames = []\r\nmaterials = []\r\n\r\nfor station in stations:\r\n    x = (float(station['location'][0]) - centerX) * scaleFactor\r\n    y = (float(station['location'][1]) - centerY) * scaleFactor\r\n    point = Point.ByCoordinates(x, y, 0)\r\n    \r\n    type = station['type']\r\n    \r\n    points.append(point)\r\n    \r\n    # Draw SemiCircles for Revit DetailCurve\r\n    normal = Vector.ByCoordinates(0,0,1)\r\n    #circles.append(Arc.ByCenterPointRadiusAngle(point, 1 * scaleFactor, 0, 180, normal))\r\n    #circles.append(Arc.ByCenterPointRadiusAngle(point, 1 * scaleFactor, 180, 360, normal))\r\n    circles.append(Circle.ByCenterPointRadius(point, 1.5 * scaleFactor))\r\n    \r\n    \r\n    # Draw full circle for filled region boundaries\r\n    boundaries.append(Circle.ByCenterPointRadius(point, getStationRadius(type) * scaleFactor))\r\n    \r\n    names.append(station['name'])\r\n    materials.append(getStationMaterial(type))\r\n    \r\n# Assign your output to the OUT variable.\r\nOUT = points, circles, boundaries, names, materials",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "cd22d8ec9d6b456cb13f1eb8a7fcda18",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "4ee5033f29c54a0eace0bb341bf0e6c8",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
