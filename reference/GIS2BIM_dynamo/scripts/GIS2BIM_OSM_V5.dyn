    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nimport System.Collections.Generic\r\nfrom System.Collections.Generic import List\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Transactions import TransactionManager\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nafilledType = IN[0]\r\niViewId = ElementId(IN[1])\r\naOSMcurves = IN[2]\r\naDebug = []\r\naFilledregions = []\r\n\r\ndef create_filledregions(boundariesLoop, ifilledType):\r\n\tfor i in range(1):\r\n\t\tprint(\"this is just genius\")\r\n\tTransactionManager.Instance.EnsureInTransaction(doc)\r\n\tfilled = FilledRegion.Create(doc, ifilledType, iViewId, boundariesLoop)\r\n\tTransactionManager.Instance.TransactionTaskDone()\r\n\taFilledregions.append(filled)\r\n\r\ni=-1\r\nfor aPolycurvelist in aOSMcurves:\r\n\ti=i+1\r\n\tifilledType = ElementId(afilledType[i])\r\n\tif aPolycurvelist>1:\r\n\t\taBoundariesLoop = []\r\n\t\taCurves = []\r\n\t\tfor aCurvelist in aPolycurvelist:\r\n\t\t\taCurves.Add(aCurvelist.ToRevitType())\r\n\t\taBoundariesLoop.Add(CurveLoop.Create(aCurves))\r\n\t\tcreate_filledregions(aBoundariesLoop, ifilledType)\r\n\telse:\r\n\t\tfor aPolycurvelist in aSubfeatures:\r\n\t\t\taCurves = []\r\n\t\t\taBoundariesLoop = []\r\n\t\t\tfor aCurvelist in aPolycurvelist:\r\n\t\t\t\taCurves.Add(aCurvelist.ToRevitType())\r\n\t\t\taBoundariesLoop.Add(CurveLoop.Create(aCurves))\r\n\t\t\tcreate_filledregions(aBoundariesLoop, ifilledType)\r\n\t\t\t\t\r\nOUT = aDebug",
      "Engine": "IronPython2",
      "VariableInputPorts": true,
      "Id": "e62c65a9ca174aad909c837038a8a830",
      "NodeType": "PythonScriptNode",
      "Inputs": [
