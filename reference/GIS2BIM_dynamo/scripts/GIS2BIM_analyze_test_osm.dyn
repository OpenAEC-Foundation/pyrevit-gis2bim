      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "RDX;\nRDY;\nScaleFactor = 1000;\nStationRadii = {\n\t\"bus\": 250,\n\t\"subway\": 1000,\n\t\"tram\": 1000,\n\t\"other\": 250\n};\nStationMaterials = {\n\t\"bus\": \"gis2bim_env_green\",\n\t\"subway\": \"gis2bim_env_blue\",\n\t\"tram\": \"gis2bim_env_yellow\",\n\t\"other\": \"gis2bim_env_gray\"\n};"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\nstations = IN[0]\r\ncenterX = IN[1]\r\ncenterY = IN[2]\r\nscaleFactor = IN[3]\r\nstationRadii = IN[4]\r\nstationMaterials = IN[5]\r\n\r\n# Place your code below this line\r\n\r\navailableStationRadii = stationRadii.keys()\r\ndef getStationRadius(type):\r\n    if type in availableStationRadii:\r\n        return stationRadii[type]\r\n    else:\r\n        return stationRadii['other']\r\n\r\navailableMaterials = stationMaterials.keys()\r\ndef getStationMaterial(type):\r\n    if type in availableMaterials:\r\n        return stationMaterials[type]\r\n    else:\r\n        return stationMaterials['other']\r\n    \r\n\r\npoints = []\r\n#circles = []\r\nboundaries = []\r\nnames = []\r\nmaterials = []\r\ntypes = []\r\n\r\nfor station in stations:\r\n    x = (float(station['location'][0]) - centerX) * scaleFactor\r\n    y = (float(station['location'][1]) - centerY) * scaleFactor\r\n    type = station['type']\r\n    radius = getStationRadius(type)\r\n    point = Point.ByCoordinates(x, y, radius)\r\n    type = station['type']\r\n\r\n    # make geometry for analyses\r\n    # Draw SemiCircles for Revit DetailCurve\r\n    # normal = Vector.ByCoordinates(0,0,1)\r\n    # circles.append(Circle.ByCenterPointRadius(point, 1.5 * scaleFactor))\r\n    # Draw full circle for filled region boundaries\r\n    boundaries.append(Circle.ByCenterPointRadius(point, getStationRadius(type) * scaleFactor))\r\n        \r\n    points.append(point)\r\n    names.append(station['name'])\r\n    materials.append(getStationMaterial(type))   \r\n    types.append(type)\r\n        \r\n# Assign your output to the OUT variable.\r\nOUT = points, names, materials, types, boundaries",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "718e2b32a9554d07baadc7f568e3a1c9",
      "NodeType": "PythonScriptNode",
