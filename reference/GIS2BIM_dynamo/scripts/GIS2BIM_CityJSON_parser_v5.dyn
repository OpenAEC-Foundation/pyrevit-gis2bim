    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport clr\r\nimport sys\r\nimport System\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager \r\nfrom RevitServices.Transactions import TransactionManager \r\n\r\nimport Autodesk \r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\nX = IN[0]\r\nY = IN[1]\r\nZ = IN[2]\r\n\r\n# Place your code below this line\r\n\r\ndef convertMToFt(distance):\r\n    return distance * 3.280839895\r\n\r\noriginXYZ = XYZ(0,0,0)\r\ntargetPosition = ProjectPosition(convertMToFt(X),convertMToFt(Y),convertMToFt(Z),0.0)\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nprojectLocation = doc.ActiveProjectLocation;\r\nprojectLocation.SetProjectPosition(originXYZ, targetPosition)\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\n# Assign your output to the OUT variable.\r\nOUT = 0",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "04b645f6788c46b3a55e6e3e8ff99b72",
      "Inputs": [
        {
          "Id": "3a0dba51050d4d2b8064e5d90f051ee0",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
