    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\ncoordsList = IN[0]\r\n\r\n# Place your code below this line\r\npoints = []\r\nX = 0\r\nY = 0\r\nfor index,coord in enumerate(coordsList):\r\n    mod = index % 3\r\n    if mod == 0:\r\n        X = coord\r\n    elif mod == 1:\r\n        Y = coord\r\n    elif mod == 2:\r\n        points.append(Point.ByCoordinates(X, Y, coord))\r\n     \r\n\r\n# Assign your output to the OUT variable.\r\nOUT = points\r\n\r\nprint('Found', len(points), 'points')\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "bebee445a7114e979729e032301378ff",
      "Inputs": [
        {
          "Id": "82af53b903784f26a97f622363ba6d66",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "2614aa2fc7434adca8ae391f15d0f9e9",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
