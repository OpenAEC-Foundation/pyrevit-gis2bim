      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# from pathlib import Path\r\n# from copy import deepcopy\r\nfrom cjio import cityjson\r\n\r\nimport time\r\n\r\nstart = time.time()\r\n\r\n# The inputs to this node will be stored as a list in the IN variables.\r\npath = IN[0]\r\nbbox = IN[1]\r\nlod = IN[2]\r\n\r\n# Place your code below this line\r\n\r\ncm = cityjson.load(path)\r\n\r\n# filter by bbox\r\ncm.upgrade_version('1.1', 3)\r\ncm = cm.get_subset_bbox(bbox, False)\r\n# filter by lod\r\n# cm.filter_lod(1.3)\r\n# extract geometry\r\nbuildings = cm.get_cityobjects(type='Building')\r\nprint('BUILDING COUNT', len(buildings))\r\nprint(cm)\r\n\r\n# Assign your output to the OUT variable.\r\nOUT = 0\r\n\r\n# DEBUG and TIMING\r\nend = time.time()\r\nprint('Execution time:', end - start, 'seconds')\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "89a0750dae684cf888f7429f082cadb4",
      "Inputs": [
